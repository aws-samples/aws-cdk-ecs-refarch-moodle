{
  "app": "npx ts-node --prefer-ts-exts bin/cdk.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.d.ts", "**/*.js", "tsconfig.json", "package*.json", "yarn.lock", "node_modules", "test"]
  },
  "context": {
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "aws-cdk:enableDiffNoFail": "true",
    "@aws-cdk/core:stackRelativeExports": "true",
    "@aws-cdk/aws-ecr-assets:dockerIgnoreSupport": true,
    "@aws-cdk/aws-kms:defaultKeyPolicies": true,
    "@aws-cdk/aws-s3:grantWriteWithoutAcl": true,
    "@aws-cdk/aws-ecs-patterns:removeDefaultDesiredCount": true,
    "@aws-cdk/aws-rds:lowercaseDbIdentifier": true,
    "@aws-cdk/aws-lambda:recognizeVersionProps": true,
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true,
    "app-config/albCertificateArn": "",
    "app-config/cfCertificateArn": "",
    "app-config/domainName": "",
    "app-config/hostName": "",
    "app-config/hostedZoneId": "",
    "app-config/cfDomain": "",
    "app-config/moodleImageUri": "",
    "app-config/serviceReplicaDesiredCount": 1,
    "app-config/serviceHealthCheckGracePeriodSeconds": 1800,
    "app-config/cfDistributionOriginTimeoutSeconds": 60,
    "app-config/rdsEventSubscriptionEmailAddress": "user@example.com",
    "app-config/rdsEngine": "aurora-serverless",
    "app-config/rdsEngineVersion": "8.0.mysql_aurora.3.10.0",
    "app-config/rdsInstanceType": "",
    "app-config/auroraServerlessMinCapacity": 0.5,
    "app-config/auroraServerlessMaxCapacity": 10,
    "app-config/cacheEngine": "valkey",
    "app-config/cacheDeploymentMode": "serverless",
    "app-config/cacheProvisionedInstanceType": "",
    "app-config/cacheServerlessMaxStorageGB": 10,
    "app-config/cacheServerlessMinCapacity": 1,
    "app-config/cacheServerlessMaxCapacity": 100
  }
}